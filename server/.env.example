# Copy this file to .env and fill in your values:
#   copy .env.example .env

# Local PostgreSQL (install Postgres or use Docker — see README)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/roster_db
# false for localhost; true for Neon/cloud
DATABASE_SSL=false

JWT_SECRET=change-this-to-a-long-random-secret
PORT=5000
CLIENT_URL=http://localhost:5000

# Google Sign-In (OAuth 2.0 — same Client ID as VITE_GOOGLE_CLIENT_ID in client/.env)
# https://console.cloud.google.com/apis/credentials → Web application
# Authorized JavaScript origins: http://localhost:5173, http://localhost:5000, your production URL
# Authorized redirect URIs: not required for Google Identity Services (button flow)
# Paste your real OAuth Web client ID (from Google Cloud — NOT the example below)
# Example shape only: 123456789012-abc123xyz.apps.googleusercontent.com
# GOOGLE_CLIENT_ID=

# Database pool (Cloud Run / VM — use PgBouncer or Neon pooler for high concurrency)
# DATABASE_POOL_MAX=20
# RATE_LIMIT_AUTH_MAX=40
# RATE_LIMIT_API_MAX=600
# Use HTTPS locally: npm run dev:https  (or set USE_HTTPS=true)
# USE_HTTPS=true
# CLIENT_URL=https://localhost:5000

# Local only — Socket.IO (not used on Vercel serverless)
ENABLE_SOCKET=true

# PDF extractor (optional — auto-detects pdf-extractor/.venv)
# PYTHON_PATH=D:\Roster Website\pdf-extractor\.venv\Scripts\python.exe
# PDF_EXTRACTOR_ROOT=../pdf-extractor

# Email (optional — leave EMAIL_ENABLED=false for local dev)
EMAIL_ENABLED=false
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=RosterPro <noreply@yourdomain.com>
HR_NOTIFY_EMAIL=admin@roster.com

# Stripe (subscriptions — use sk_test_ / pk_test_ for development)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_BUSINESS_MONTHLY_PRICE_ID=price_...
STRIPE_BUSINESS_ANNUAL_PRICE_ID=price_...

# Razorpay (priority 2 — after Stripe; India / APAC)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PRO_MONTHLY_PLAN_ID=plan_...
RAZORPAY_PRO_ANNUAL_PLAN_ID=plan_...
RAZORPAY_BUSINESS_MONTHLY_PLAN_ID=plan_...
RAZORPAY_BUSINESS_ANNUAL_PLAN_ID=plan_...
