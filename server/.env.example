# Copy this file to .env and fill in your values:
#   copy .env.example .env

# Local PostgreSQL (install Postgres or use Docker — see README)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/roster_db
# false for localhost; true for Neon/cloud
DATABASE_SSL=false

JWT_SECRET=change-this-to-a-long-random-secret
PORT=5000
CLIENT_URL=http://localhost:5000
# Use HTTPS locally: npm run dev:https  (or set USE_HTTPS=true)
# USE_HTTPS=true
# CLIENT_URL=https://localhost:5000

# Local only — Socket.IO (not used on Vercel serverless)
ENABLE_SOCKET=true

# PDF extractor (optional — auto-detects pdf-extractor/.venv)
# PYTHON_PATH=D:\Roster Website\pdf-extractor\.venv\Scripts\python.exe
# PDF_EXTRACTOR_ROOT=../pdf-extractor

# Email (optional — leave EMAIL_ENABLED=false for local dev)
EMAIL_ENABLED=false
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=RosterPro <noreply@yourdomain.com>
HR_NOTIFY_EMAIL=admin@roster.com
