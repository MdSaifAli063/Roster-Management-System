# Local dev: leave unset — Vite proxies /api to localhost:5000 (see vite.config.js)

# Vercel production (required when API is on Render/Railway/etc.):
# VITE_API_URL=https://your-api.onrender.com/api
# VITE_SOCKET_URL=https://your-api.onrender.com
# (Socket URL is optional if same host as API — derived from VITE_API_URL)
