# Copy these into Vercel → Project → Settings → Environment Variables
# (Production + Preview). Do NOT commit real secrets.

# Neon PostgreSQL (required)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_SSL=true

# Auth (required) — use a long random string
JWT_SECRET=replace-with-64-char-random-secret

# Email (optional)
EMAIL_ENABLED=false
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=RosterPro <noreply@yourdomain.com>
HR_NOTIFY_EMAIL=admin@yourcompany.com

# Frontend — leave UNSET for all-in-one Vercel deploy (API at /api on same domain)
# VITE_API_URL=

# Notification polling interval (optional, milliseconds)
# VITE_NOTIFICATION_POLL_MS=20000

# Custom domain only — comma-separated allowed origins for CORS
# CLIENT_URL=https://app.yourcompany.com
