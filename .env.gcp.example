# Set these in Cloud Run → Edit & deploy → Variables & secrets
# (Or use Secret Manager for sensitive values)

# Neon (easiest): paste connection string from neon.tech
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_SSL=true

JWT_SECRET=use-a-long-random-secret-at-least-32-chars

# After first deploy, set to your Cloud Run URL (no trailing slash)
CLIENT_URL=https://roster-app-xxxxxxxx-uc.a.run.app

EMAIL_ENABLED=false
ENABLE_SOCKET=false
TRUST_PROXY=true
DATABASE_POOL_MAX=20

# Google OAuth (set same value in Cloud Build / Docker as VITE_GOOGLE_CLIENT_ID)
# GOOGLE_CLIENT_ID=
# VITE_GOOGLE_CLIENT_ID=  (build-time for client — pass as Docker build-arg)

# Stripe / Razorpay — required for paid subscriptions
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# INBOUND_EMAIL_SECRET=  (required in production for /api/inbound/pdf)

# Optional email
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=RosterPro <noreply@yourdomain.com>
# HR_NOTIFY_EMAIL=admin@yourcompany.com
