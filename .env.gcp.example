# Set these in Cloud Run → Edit & deploy → Variables & secrets
# (Or use Secret Manager for sensitive values)

# Neon (easiest): paste connection string from neon.tech
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_SSL=true

JWT_SECRET=use-a-long-random-secret-at-least-32-chars

# After first deploy, set to your Cloud Run URL (no trailing slash)
CLIENT_URL=https://roster-app-xxxxxxxx-uc.a.run.app

EMAIL_ENABLED=false
ENABLE_SOCKET=false

# Optional email
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=RosterPro <noreply@yourdomain.com>
# HR_NOTIFY_EMAIL=admin@yourcompany.com
